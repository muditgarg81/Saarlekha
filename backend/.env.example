# ==========================================
# Saarlekha Backend Environment Configuration
# ==========================================

# Server configuration
PORT=5000
NODE_ENV=production

# The URL of your React frontend. Used for building verification and reset links.
# Set this to the production domain: https://saarlekha.com (or https://www.saarlekha.com / https://app.saarlekha.com)
APP_URL=https://saarlekha.com

# PostgreSQL Connection URLs
# DATABASE_URL is for standard pool connection. DIRECT_URL is for direct schema changes/migrations (useful with pgBouncer / Neon).
DATABASE_URL="postgresql://user:password@host/db?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@host/db?sslmode=require"

# JWT Token Secret (must be a strong unique sequence of 32+ characters)
JWT_SECRET="generate_a_random_secure_secret_key_for_jwt_session"

# Aadhaar Encryption Key (AES-256 requires exactly 32 bytes/characters)
# MUST be kept secret and same across redeployments to ensure Aadhaar data remains decryptable.
AADHAAR_ENCRYPTION_KEY="use_32_char_encryption_key_here"

# Google OAuth API Credentials
# Configure these in the Google Cloud Console (credentials API)
# Ensure you add 'https://saarlekha.com' to Authorized JavaScript origins.
GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# SMTP Configuration for Onboarding & Verification Emails
# When configured, Saarlekha will send real emails for user registration and invite links.
# If omitted, emails will be logged directly to the server terminal/console (dev mode fallback).
SMTP_HOST="smtp.mailgun.org"
SMTP_PORT=587
SMTP_USER="postmaster@yourdomain.com"
SMTP_PASS="smtp_password"
SMTP_FROM="Saarlekha <no-reply@saarlekha.com>"
