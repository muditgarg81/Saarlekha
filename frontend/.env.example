# ===========================================
# Saarlekha Frontend Environment Configuration
# ===========================================

# API server endpoint where the backend Express app is hosted.
# For production (e.g. saarlekha.com), set this to the backend API route.
# If hosting frontend and backend on the same domain (e.g. using reverse proxy / Nginx / Cloudflare):
# VITE_API_URL=https://saarlekha.com/api
# If hosting backend on a separate subdomain:
# VITE_API_URL=https://api.saarlekha.com/api
VITE_API_URL=https://saarlekha.com/api
